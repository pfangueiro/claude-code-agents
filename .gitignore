# Claude Agents - Minimal .gitignore

# History (personal data, don't commit)
.claude/history/

# Logs
*.log

# OS files
.DS_Store
._*
Thumbs.db

# Claude local settings (personal, not shared)
.claude/settings.local.json
.claude/.DS_Store

# MCP config (contains machine-specific paths - use .mcp.json.example as template)
.mcp.json

# Deployment marker — written by install.sh into deployed projects only.
# Never belongs in the source tree (install.sh has a guard, this is defense in depth).
.claude/.framework-version

# install.sh creates these automatically during --update as local rollback snapshots.
.claude-backup-*/

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.temp
*.backup

# Archives
*.tar.gz
*.zip